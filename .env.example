# Environment: development | production
APP_ENV=development

# Set to true to enable live OpenAI calls for the filter layer
# When false (default) the pipeline runs fully in heuristic/mock mode
USE_LIVE_PROVIDER_CALLS=false

# Required only when USE_LIVE_PROVIDER_CALLS=true
OPENAI_API_KEY=

# Verbosity defaults (characters) — overridden per-profile at runtime
DEFAULT_CHILD_VERBOSITY_LIMIT=90
DEFAULT_PARENT_VERBOSITY_LIMIT=140
